# Shell scripts and systemd unit files MUST use LF, or they fail with
# "bad interpreter" / fail to parse on the Linux deploy target. This is enforced
# here so a Windows checkout (core.autocrlf=true) can't rewrite them to CRLF.
*.sh        text eol=lf
*.service   text eol=lf
*.timer     text eol=lf
entrypoint.sh text eol=lf
